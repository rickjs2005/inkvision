{
  "name": "inkvision",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @inkvision/db generate",
    "db:migrate": "pnpm --filter @inkvision/db migrate",
    "db:seed": "pnpm --filter @inkvision/db seed",
    "db:studio": "pnpm --filter @inkvision/db studio",
    "setup:local": "node scripts/setup-local-db.mjs",
    "seed:demo": "pnpm --filter @inkvision/web seed:demo",
    "infra:up": "docker compose -f docker/compose.dev.yml up -d",
    "infra:down": "docker compose -f docker/compose.dev.yml down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "sharp"]
  }
}
