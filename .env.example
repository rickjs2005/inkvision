# ─────────────── Core ───────────────
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ROOT_DOMAIN=localhost:3000

# ─────────────── Database ───────────────
# Dev sem Docker: rode `pnpm setup:local` — ele sobe o Postgres local do Prisma
# e escreve o DATABASE_URL aqui automaticamente (algo como a linha abaixo).
# DATABASE_URL=postgres://postgres:postgres@localhost:51214/postgres?sslmode=disable&pgbouncer=true
# Alternativa com Docker (pnpm infra:up):
DATABASE_URL=postgresql://inkvision:inkvision@localhost:5432/inkvision?schema=public

# ─────────────── Redis ───────────────
REDIS_URL=redis://localhost:6379

# ─────────────── Auth (Better Auth) ───────────────
BETTER_AUTH_SECRET=change-me-generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Login social Google (opcional — sem o par, o botão degrada p/ "em breve").
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────── Realtime ───────────────
REALTIME_PORT=4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000
REALTIME_EMIT_URL=http://localhost:4000
REALTIME_EMIT_SECRET=dev-emit-secret-change-me

# ─────────────── Cloudflare R2 ───────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=inkvision-media
R2_PUBLIC_URL=

# ─────────────── Stripe ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PLATFORM_FEE_PERCENT=10

# ─────────────── E-mail transacional (Resend) ───────────────
# Sem a chave, os e-mails só são logados no console (MockEmailService).
RESEND_API_KEY=
EMAIL_FROM=InkVision <onboarding@resend.dev>

# ─────────────── AI layer (provider-agnostic) ───────────────
# mock (padrão sem a env var) não chama nenhum provedor real — essencial pra
# testar o fluxo de simulação localmente sem FAL_API_KEY. Troque pra "fal" só
# quando tiver a chave (senão a simulação dentro do pedido falha).
AI_SIMULATION_PROVIDER=mock        # mock | fal | replicate | openai | gemini | stability
AI_IMAGE_PROVIDER=fal
FAL_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=
STABILITY_API_KEY=
