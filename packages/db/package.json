{
  "name": "@inkvision/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tenant": "./src/tenant-extension.ts"
  },
  "scripts": {
    "dev": "prisma dev --name inkvision",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "rls": "tsx prisma/apply-rls.ts",
    "setup": "prisma migrate deploy && tsx prisma/apply-rls.ts && tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@inkvision/config": "workspace:*",
    "@inkvision/shared": "workspace:*",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
